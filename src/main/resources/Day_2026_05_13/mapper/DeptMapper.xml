<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="Day_2026_05_13.mapper.DeptMapper">
    <delete id="deleteByID">
        delete from dept where id = #{id};
    </delete>

    <select id="list" resultType="Day_2026_05_13.pojo.Dept">
        select id,
        name,
        create_time,
        update_time
        from dept
        order by id
    </select>



</mapper>